#!/usr/bin/env bash
# Wrapper for xdg-open in Selkies webtop container.
# NW.js calls xdg-open for OAuth URLs. We launch chromium inside the
# container so the user can complete login in a real browser window.

URL="$1"
LOG="/tmp/streamlink-twitch-gui.log"

echo "[xdg-open] URL: $URL" | tee -a "$LOG"

# Twitch OAuth login is blocked in container browsers due to integrity checks.
# Instead, use the Twitch OAuth Login desktop shortcut or run:
#   python3 /usr/local/bin/twitch-oauth-device-flow

echo "[xdg-open] ==========================================" | tee -a "$LOG"
echo "[xdg-open] TWITCH OAUTH LOGIN BLOCKED IN CONTAINER" | tee -a "$LOG"
echo "[xdg-open] Browser integrity checks prevent login." | tee -a "$LOG"
echo "[xdg-open] " | tee -a "$LOG"
echo "[xdg-open] To log in, use one of these methods:" | tee -a "$LOG"
echo "[xdg-open]  1. Run tools/get-twitch-token.py on your PC" | tee -a "$LOG"
echo "[xdg-open]     and paste the token into Streamlink Twitch GUI" | tee -a "$LOG"
echo "[xdg-open]  2. In Streamlink Twitch GUI: Login -> Use Access Token" | tee -a "$LOG"
echo "[xdg-open]     Generate token at https://twitchtokengenerator.com/" | tee -a "$LOG"
echo "[xdg-open]     (token must start with 'oauth:' for the GUI)" | tee -a "$LOG"
echo "[xdg-open] ==========================================" | tee -a "$LOG"

# Save URL for reference
echo "$URL" > /tmp/oauth-url.txt

notify-send "Streamlink Twitch GUI" "Twitch login blocked in container. Use the Twitch OAuth Login shortcut on the desktop." 2>/dev/null || true

exit 0
