#!/usr/bin/env bash

export HOME="/config"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
export DISPLAY=:0

LOG="/tmp/streamlink-twitch-gui.log"
echo "[autostart] === START === $(date)" | tee -a "$LOG"
echo "[autostart] autostart file: $(readlink -f "$0")" | tee -a "$LOG"
echo "[autostart] running as: $(whoami) uid=$(id -u)" | tee -a "$LOG"
echo "[autostart] labwc pid: $(pgrep labwc || echo NONE)" | tee -a "$LOG"
echo "[autostart] WAYLAND_DISPLAY=$WAYLAND_DISPLAY DISPLAY=$DISPLAY" | tee -a "$LOG"

sleep 3

# Make our OAuth URL visible
echo "[autostart] OAuth URLs will be logged to /tmp/streamlink-twitch-gui.log" | tee -a "$LOG"

# Override xdg-open for OAuth in headless container
export PATH="/usr/local/bin:$PATH"
mkdir -p "$HOME/.config/xdg-settings"

# Config dirs
mkdir -p "$HOME/.config/streamlink" "$HOME/.config/streamlink-twitch-gui"

# Default streamlink config
if [ ! -f "$HOME/.config/streamlink/config" ]; then
    cat > "$HOME/.config/streamlink/config" <<'EOF'
[player]
player=mpv --force-window=immediate --cache=yes
[stream]
hls-segment-threads=4
EOF
fi

STG="/opt/streamlink-twitch-gui/streamlink-twitch-gui"

if [ ! -x "$STG" ]; then
    echo "[autostart] ERROR: $STG not found" | tee -a "$LOG"
    sleep infinity
fi

# Remove stale Chromium SingletonLock files from previous crashed runs
# so NW.js can start even if it didn't shut down cleanly.
STG_PROFILE="$HOME/.config/streamlink-twitch-gui"
cleanup_locks() {
    echo "[autostart] cleaning locks in $STG_PROFILE" | tee -a "$LOG"
    for lock in SingletonLock SingletonSocket SingletonCookie; do
        if [ -e "$STG_PROFILE/$lock" ] || [ -L "$STG_PROFILE/$lock" ]; then
            echo "[autostart] removing stale $lock" | tee -a "$LOG"
            rm -rf "$STG_PROFILE/$lock"
        fi
    done
    # Also remove NW.js temp socket dirs that might be left over
    rm -rf /tmp/.io.nwjs.* 2>/dev/null || true
}

FLAGS=(
    --ozone-platform=x11
    --no-sandbox
    --disable-gpu-sandbox
    --disable-setuid-sandbox
    --disable-dev-shm-usage
    --no-first-run
    --no-default-browser-check
    --disable-background-networking
    --disable-background-timer-throttling
    --disable-default-apps
    --disable-hang-monitor
    --disable-popup-blocking
    --disable-prompt-on-repost
    --disable-sync
    --force-color-profile=srgb
    --password-store=basic
    --use-mock-keychain
)

# Try up to 3 times: clean locks, launch, if exit 21 clean and retry
for attempt in 1 2 3; do
    cleanup_locks
    echo "[autostart] launching (attempt $attempt): $STG ${FLAGS[*]}" | tee -a "$LOG"

    "$STG" "${FLAGS[@]}" >> "$LOG" 2>&1
    EXIT=$?
    echo "[autostart] STG exited code $EXIT (attempt $attempt)" | tee -a "$LOG"

    if [ "$EXIT" -ne 21 ]; then
        break
    fi
    echo "[autostart] exit 21 = profile locked, retrying after cleanup..." | tee -a "$LOG"
    sleep 2
done

echo "[autostart] final exit code: $EXIT" | tee -a "$LOG"

# Keep session alive for debugging
sleep infinity
